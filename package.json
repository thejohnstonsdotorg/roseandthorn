{
  "name": "roseandthorn",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "build:preview": "eas build --platform android --profile preview",
    "submit:android": "eas submit --platform android --latest",
    "release:android": "npm run build:android && npm run submit:android",
    "store:check": "node scripts/check-store-readiness.mjs",
    "store:check:strict": "node scripts/check-store-readiness.mjs --strict",
    "store:generate-screenshots": "node scripts/generate-store-screenshots.mjs",
    "store:capture-screenshots": "bash scripts/capture-screenshots.sh",
    "release:preflight": "node_modules/.bin/tsc --noEmit && npm run store:check:strict",
    "version": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.34",
    "expo-file-system": "~19.0.22",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-mediapipe-image-gen": "file:./modules/expo-mediapipe-image-gen",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "^3.19.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "autoprefixer": "^10.5.0",
    "babel-preset-expo": "~54.0.10",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated"
      ]
    }
  },
  "private": true
}
