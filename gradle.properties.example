# ─── Release signing ──────────────────────────────────────────────────────────
# For LOCAL release builds only. EAS Build injects these automatically from its
# managed credentials — you do NOT need to set them when using `eas build`.
#
# Copy to android/gradle.properties (gitignored) and fill in values:
#
# Generate a keystore locally (if not using EAS managed credentials):
#   keytool -genkey -v -keystore roseandthorn-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias roseandthorn
#
# Back up the JKS file to a password manager. Losing the upload keystore
# prevents app updates unless you use Play App Signing key rotation.
# ─────────────────────────────────────────────────────────────────────────────

RELEASE_STORE_FILE=../roseandthorn-upload.jks
RELEASE_STORE_PASSWORD=your-keystore-password
RELEASE_KEY_ALIAS=roseandthorn
RELEASE_KEY_PASSWORD=your-key-password
